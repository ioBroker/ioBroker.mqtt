{
    "compileOnSave": true,
    "compilerOptions": {
        "noEmit": true,
        "allowJs": true,
        "checkJs": true,
        "outDir": "./build/",
        "rootDir": "./src/",
        "sourceMap": true,
        "inlineSources": true,
        "module": "node16",
        "moduleResolution": "node16",
        "resolveJsonModule": true,
        "strict": true,
        "noImplicitAny": true,
        "target": "es2022",
        "esModuleInterop": true,
        "types": ["@types/node", "@iobroker/types"],
    },
    "include": ["src/**/*.ts"]
}
